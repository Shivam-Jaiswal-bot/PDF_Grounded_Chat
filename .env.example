# Pick ONE provider — set the matching key.
LLM_PROVIDER=

# Groq (OpenAI-compatible, fast + free tier)
GROQ_API_KEY=gsk_your_groq_key_here
MODEL=llama-3.3-70b-versatile

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# App
PORT=3000

# Retrieval
TOP_K=4
SIMILARITY_THRESHOLD=0.30    # below this, agent refuses (out-of-scope)
